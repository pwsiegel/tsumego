# Pretrained-model cache (auto-downloaded on first train run)
api/yolov8n.pt

# All data + model weights live under $GOAPP_DATA_DIR (default ~/data/go-app).
# The api/training_data and api/models trees should never be created inside
# the repo — if they show up (from a stale code path) they're ignored here
# so `git clean -dfx` can't surprise you.
api/training_data/
api/models/

# Tooling caches
.claude/

# Logs
*.log
