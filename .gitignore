# OS / editor
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
*.suo
*.sw?

# Node
node_modules/
dist/
dist-ssr/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
*.egg-info/

# Pretrained-model cache (auto-downloaded on first train run)
api/yolov8n.pt
# Derived YOLO training datasets (regenerated from labeled sources)
api/training_data/yolo/
api/training_data/yolo_synth/
# PDF-ingest crops (regenerated by re-ingesting a PDF through the tuning UI)
api/training_data/stone_tasks/
# Synth data (regenerated by `python -m goapp_api.synth.gen`)
api/training_data/synth_pages/
# Derived from synth_pages/ by extract_*_crops scripts
api/training_data/synth_stone_crops/
api/training_data/synth_edge_crops/
api/training_data/synth_grid_crops/
api/training_data/synth_snap_crops/
# Training run artifacts (ultralytics runs)
api/models/runs/

# Tooling caches
.claude/

# Logs
*.log
